    public java.util.List<PresupuestoNoCliente> buscarPorTipoProfesional(String tipoProfesional, Long empresaId) {
        // Implementación básica - puede mejorarse según necesidades
        List<PresupuestoNoCliente> presupuestos = repository.findAll();
        // Calcular campos calculados
        presupuestos.forEach(PresupuestoNoCliente::calcularCamposCalculados);
        return presupuestos;
    }

    /**
     * Sincroniza los datos del cliente desde el presupuesto hacia la obra asociada.
     * Este método es llamado automáticamente después de guardar un presupuesto.
     * 
     * @param presupuesto El presupuesto con los datos actualizados
     */
    private void sincronizarDatosClienteConObra(PresupuestoNoCliente presupuesto) {
        if (presupuesto.getObraId() == null) {
            return;
        }
        
        try {
            Optional<Obra> obraOpt = obraRepository.findById(presupuesto.getObraId());
            
            if (obraOpt.isEmpty()) {
                log.warn("⚠️ Obra con ID {} no encontrada para presupuesto {}", 
                    presupuesto.getObraId(), presupuesto.getId());
                return;
            }
            
            Obra obra = obraOpt.get();
            
            EstadoObra estadoObra = obra.getEstadoEnum();
            if (estadoObra == EstadoObra.FINALIZADA || estadoObra == EstadoObra.CANCELADA) {
                log.info("ℹ️ Obra {} está {} - No se actualizan datos del cliente", 
                    obra.getId(), estadoObra.getDisplayName());
                return;
            }
            
            boolean actualizado = false;
            
            if (presupuesto.getNombreSolicitante() != null && 
                !presupuesto.getNombreSolicitante().equals(obra.getNombreSolicitante())) {
                obra.setNombreSolicitante(presupuesto.getNombreSolicitante());
                actualizado = true;
            }
            
            if (presupuesto.getTelefono() != null && 
                !presupuesto.getTelefono().equals(obra.getTelefono())) {
                obra.setTelefono(presupuesto.getTelefono());
                actualizado = true;
            }
            
            if (presupuesto.getMail() != null && 
                !presupuesto.getMail().equals(obra.getMail())) {
                obra.setMail(presupuesto.getMail());
                actualizado = true;
            }
            
            if (presupuesto.getDireccionParticular() != null && 
                !presupuesto.getDireccionParticular().equals(obra.getDireccionParticular())) {
                obra.setDireccionParticular(presupuesto.getDireccionParticular());
                actualizado = true;
            }
            
            if (actualizado) {
                obraRepository.save(obra);
                log.info("✅ Datos del cliente sincronizados: Presupuesto {} → Obra {}", 
                    presupuesto.getId(), obra.getId());
            }
            
        } catch (Exception e) {
            log.error("❌ Error al sincronizar datos con obra {}: {}", 
                presupuesto.getObraId(), e.getMessage(), e);
        }
    }

    /**
     * Procesa los costos iniciales del presupuesto (crear o actualizar).
     * 
     * @param presupuesto Presupuesto guardado
     * @param dto DTO con datos de costos iniciales (puede ser null)
     */
    private void procesarItemsCalculadora(PresupuestoNoCliente presupuesto, List<ItemCalculadoraPresupuestoDTO> itemsDTO) {
        if (itemsDTO == null || itemsDTO.isEmpty()) {
            log.debug("No se proporcionaron items de calculadora para el presupuesto {}", presupuesto.getId());
            // Si viene vacío, eliminar todos los items existentes
            itemCalculadoraRepository.deleteByPresupuestoNoClienteId(presupuesto.getId());
            return;
        }

        try {
            // ESTRATEGIA: DELETE + INSERT
            // Eliminar todos los items existentes del presupuesto
            itemCalculadoraRepository.deleteByPresupuestoNoClienteId(presupuesto.getId());
            log.debug("🗑️ Items de calculadora anteriores eliminados para presupuesto {}", presupuesto.getId());

            // Insertar los nuevos items
            for (ItemCalculadoraPresupuestoDTO dto : itemsDTO) {
                ItemCalculadoraPresupuesto item = new ItemCalculadoraPresupuesto();
                
                // Relaciones
                item.setPresupuestoNoCliente(presupuesto);
                item.setEmpresa(presupuesto.getEmpresa());
                
                // Datos del item
                item.setTipoProfesional(dto.getTipoProfesional());
                item.setCantidadJornales(dto.getCantidadJornales());
                item.setImporteJornal(dto.getImporteJornal());
                item.setSubtotalManoObra(dto.getSubtotalManoObra() != null ? dto.getSubtotalManoObra() : BigDecimal.ZERO);
                item.setMateriales(dto.getMateriales());
                item.setTotalManual(dto.getTotalManual());
                item.setTotal(dto.getTotal());
                item.setEsModoManual(dto.getEsModoManual());
                
                // Campos adicionales
                item.setSubtotalMateriales(dto.getSubtotalMateriales());
                
                // ========== CAMPOS DE GASTOS GENERALES ==========
                item.setEsGastoGeneral(dto.getEsGastoGeneral() != null ? dto.getEsGastoGeneral() : false);
                item.setSubtotalGastosGenerales(dto.getSubtotalGastosGenerales());
                item.setDescripcionGastosGenerales(dto.getDescripcionGastosGenerales());
                item.setObservacionesGastosGenerales(dto.getObservacionesGastosGenerales());
                
                // Calcular totales (por si vienen inconsistentes desde frontend)
                item.calcularTotales();
                
                // Validar antes de guardar
                item.validar();
                
                // Guardar item principal primero
                ItemCalculadoraPresupuesto itemGuardado = itemCalculadoraRepository.save(item);
                
                // Procesar profesionales desglosados
                if (dto.getProfesionales() != null && !dto.getProfesionales().isEmpty()) {
                    for (ProfesionalCalculadoraDTO profDto : dto.getProfesionales()) {
                        ProfesionalCalculadora profesional = new ProfesionalCalculadora();
                        profesional.setItemCalculadora(itemGuardado);
                        profesional.setEmpresa(presupuesto.getEmpresa());
                        profesional.setFrontendId(profDto.getId());
                        profesional.setTipo(profDto.getTipo());
                        profesional.setNombre(profDto.getNombre());
                        profesional.setTelefono(profDto.getTelefono());
                        profesional.setUnidad(profDto.getUnidad());
                        profesional.setCantidadJornales(profDto.getCantidadJornales());
                        profesional.setImporteJornal(profDto.getImporteJornal());
                        profesional.setSubtotal(profDto.getSubtotal());
                        profesional.setSinCantidad(profDto.getSinCantidad() != null ? profDto.getSinCantidad() : false);
                        profesional.setSinImporte(profDto.getSinImporte() != null ? profDto.getSinImporte() : false);
                        
                        profesionalCalculadoraRepository.save(profesional);
                    }
                }
                
                // Procesar materiales desglosados
                if (dto.getMaterialesLista() != null && !dto.getMaterialesLista().isEmpty()) {
                    for (MaterialCalculadoraDTO matDto : dto.getMaterialesLista()) {
                        MaterialCalculadora material = new MaterialCalculadora();
                        material.setItemCalculadora(itemGuardado);
                        material.setEmpresa(presupuesto.getEmpresa());
                        material.setFrontendId(matDto.getId());
                        material.setNombre(matDto.getNombre());
                        material.setDescripcion(matDto.getDescripcion());
                        material.setUnidad(matDto.getUnidad());
                        material.setCantidad(matDto.getCantidad());
                        material.setPrecio(matDto.getPrecio());
                        material.setSubtotal(matDto.getSubtotal());
                        
                        materialCalculadoraRepository.save(material);
                    }
                }
                
                // ========== PROCESAR GASTOS GENERALES ==========
                if (Boolean.TRUE.equals(dto.getEsGastoGeneral()) && 
                    dto.getGastosGenerales() != null && !dto.getGastosGenerales().isEmpty()) {
                    
                    log.info("📥 Recibido item Gastos Generales con {} gastos: {}", 
                        dto.getGastosGenerales().size(), 
                        dto.getGastosGenerales().stream()
                            .map(g -> g.getDescripcion() + "=" + g.getSubtotal())
                            .toList());
                    
                    log.debug("💾 Guardando {} gastos generales para item_id {}", 
                        dto.getGastosGenerales().size(), itemGuardado.getId());
                    
                    int orden = 1;
                    for (GastoGeneralDTO gastoDto : dto.getGastosGenerales()) {
                        PresupuestoGastoGeneral gasto = new PresupuestoGastoGeneral();
                        gasto.setItemCalculadora(itemGuardado);
                        gasto.setEmpresa(presupuesto.getEmpresa());
                        gasto.setDescripcion(gastoDto.getDescripcion());
                        gasto.setCantidad(gastoDto.getCantidad() != null ? gastoDto.getCantidad() : BigDecimal.ONE);
                        gasto.setPrecioUnitario(gastoDto.getPrecioUnitario() != null ? gastoDto.getPrecioUnitario() : BigDecimal.ZERO);
                        gasto.setSubtotal(gastoDto.getSubtotal() != null ? gastoDto.getSubtotal() : BigDecimal.ZERO);
                        gasto.setSinCantidad(gastoDto.getSinCantidad() != null ? gastoDto.getSinCantidad() : false);
                        gasto.setSinPrecio(gastoDto.getSinPrecio() != null ? gastoDto.getSinPrecio() : false);
                        gasto.setOrden(gastoDto.getOrden() != null ? gastoDto.getOrden() : orden++);
                        
                        // Configurar defaults y validar
                        gasto.configurarDefaults();
                        gasto.validar();
                        
                        gastoGeneralRepository.save(gasto);
                    }
                    
                    log.info("✅ Guardados {} gastos generales exitosamente para item_id {}", 
                        dto.getGastosGenerales().size(), itemGuardado.getId());
                    
                    // 🧮 CALCULAR Y ASIGNAR TOTALES DE GASTOS GENERALES
                    BigDecimal totalGastosGenerales = BigDecimal.ZERO;
                    for (GastoGeneralDTO gastoDto : dto.getGastosGenerales()) {
                        BigDecimal subtotalGasto = gastoDto.getSubtotal() != null ? gastoDto.getSubtotal() : BigDecimal.ZERO;
                        totalGastosGenerales = totalGastosGenerales.add(subtotalGasto);
                    }
                    
                    // Asignar subtotal de gastos generales
                    itemGuardado.setSubtotalGastosGenerales(totalGastosGenerales);
                    
                    // Calcular total completo del item
                    BigDecimal subtotalManoObra = itemGuardado.getSubtotalManoObra() != null ? itemGuardado.getSubtotalManoObra() : BigDecimal.ZERO;
                    BigDecimal subtotalMateriales = itemGuardado.getSubtotalMateriales() != null ? itemGuardado.getSubtotalMateriales() : BigDecimal.ZERO;
                    
                    BigDecimal totalCompleto = subtotalManoObra
                        .add(subtotalMateriales)
                        .add(totalGastosGenerales);
                    
                    itemGuardado.setTotal(totalCompleto);
                    
                    log.info("🧮 TOTALES CALCULADOS para item_id {}: subtotalGastosGenerales={}, total={}", 
                        itemGuardado.getId(), totalGastosGenerales, totalCompleto);
                    
                    // Guardar el item con los totales actualizados
                    itemCalculadoraRepository.save(itemGuardado);
                }
            }
            
            log.info("✅ {} items de calculadora procesados para presupuesto {}", 
                itemsDTO.size(), presupuesto.getId());

        } catch (IllegalStateException e) {
            log.error("❌ Error de validación al procesar items de calculadora para presupuesto {}: {}", 
                presupuesto.getId(), e.getMessage());
            throw new IllegalArgumentException("Error de validación en items de calculadora: " + e.getMessage(), e);
        } catch (Exception e) {
            log.error("❌ Error al procesar items de calculadora para presupuesto {}: {}", 
                presupuesto.getId(), e.getMessage(), e);
            throw new IllegalArgumentException("Error al procesar items de calculadora: " + e.getMessage(), e);
        }
    }

    /**
     * Procesa y guarda/actualiza los costos iniciales asociados a un presupuesto.
     * 
     * @param presupuesto Presupuesto al que se asocian los costos
     * @param dto DTO con datos de costos iniciales (puede ser null)
     */
    private void procesarCostosIniciales(PresupuestoNoCliente presupuesto, PresupuestoCostoInicialDTO dto) {
        if (dto == null) {
            log.debug("No se proporcionaron costos iniciales para el presupuesto {}", presupuesto.getId());
            return;
        }

        try {
            // Buscar si ya existe un costo inicial para este presupuesto
            Optional<PresupuestoCostoInicial> costoExistente = 
                costoInicialRepository.findByPresupuestoNoClienteId(presupuesto.getId());

            PresupuestoCostoInicial costoInicial;
            
            if (costoExistente.isPresent()) {
                // ACTUALIZAR existente
                costoInicial = costoExistente.get();
                log.debug("📝 Actualizando costos iniciales existentes para presupuesto {}", presupuesto.getId());
            } else {
                // CREAR nuevo
                costoInicial = new PresupuestoCostoInicial();
                costoInicial.setPresupuestoNoCliente(presupuesto);
                log.debug("➕ Creando nuevos costos iniciales para presupuesto {}", presupuesto.getId());
            }

            // Mapear datos del DTO a la entidad
            costoInicial.setMetrosCuadrados(dto.getMetrosCuadrados());
            costoInicial.setImportePorMetro(dto.getImportePorMetro());
            costoInicial.setPorcentajeProfesionales(dto.getPorcentajeProfesionales());
            costoInicial.setPorcentajeMateriales(dto.getPorcentajeMateriales());
            costoInicial.setPorcentajeOtrosCostos(dto.getPorcentajeOtrosCostos());

            // Calcular montos derivados
            costoInicial.calcularMontos();

            // Validar suma de porcentajes
            if (!costoInicial.validarSumaPorcentajes()) {
                throw new IllegalArgumentException(
                    "La suma de porcentajes no puede exceder 100. " +
                    "Profesionales: " + dto.getPorcentajeProfesionales() + "%, " +
                    "Materiales: " + dto.getPorcentajeMateriales() + "%, " +
                    "Otros Costos: " + dto.getPorcentajeOtrosCostos() + "%"
                );
            }

            // Guardar
            costoInicialRepository.save(costoInicial);
            
            log.info("✅ Costos iniciales procesados para presupuesto {}: {} m² x ${} = ${}", 
                presupuesto.getId(), 
                costoInicial.getMetrosCuadrados(),
                costoInicial.getImportePorMetro(),
                costoInicial.getTotalEstimado());

        } catch (Exception e) {
            log.error("❌ Error al procesar costos iniciales para presupuesto {}: {}", 
                presupuesto.getId(), e.getMessage(), e);
            throw new IllegalArgumentException("Error al procesar costos iniciales: " + e.getMessage(), e);
        }
    }
    
    // ========== MÉTODOS DE RECÁLCULO DE TOTALES ==========
    
    /**
     * Recalcula el total del item basado en sus subtotales consolidados.
     * CONSERVATIVO: Solo recalcula si hay subtotales válidos.
     */
    private void recalcularTotalItem(ItemCalculadoraPresupuesto item) {
        BigDecimal nuevoTotal = BigDecimal.ZERO;
        boolean haySubtotales = false;
        
        BigDecimal totalAnterior = item.getTotal() != null ? item.getTotal() : BigDecimal.ZERO;
        if (items == null || items.isEmpty()) {
            log.warn("⚠️ No hay items de calculadora para consolidar mayores costos");
            return;
        }
        
        // Guardar total original para auditoría
        Double totalPresupuestoOriginal = presupuesto.getTotalPresupuesto() != null ? presupuesto.getTotalPresupuesto().doubleValue() : 0.0;
        
        // PASO 2: Consolidar mayores costos en cada item de itemsCalculadora - APLICACIÓN SELECTIVA
        log.info("📊 Aplicación selectiva de mayores costos:");
        log.info("   - Profesionales: {}", Boolean.TRUE.equals(dto.getAplicarMayoresCostosAProfesionales()));
        log.info("   - Materiales: {}", Boolean.TRUE.equals(dto.getAplicarMayoresCostosAMateriales()));
        log.info("   - Otros Costos: {}", Boolean.TRUE.equals(dto.getAplicarMayoresCostosAOtrosCostos()));
        log.info("   - Honorarios: {}", Boolean.TRUE.equals(dto.getAplicarMayoresCostosAHonorarios()));
        
        int itemsConsolidados = 0;
        
        for (ItemCalculadoraPresupuesto item : items) {
            boolean itemModificado = false;
            
            // CONSOLIDACIÓN SELECTIVA POR CATEGORÍA - Solo modificar categorías seleccionadas
            
            // 1. PROFESIONALES - Solo si está seleccionado
            if (Boolean.TRUE.equals(dto.getAplicarMayoresCostosAProfesionales()) && 
                dto.getMayorCostoProfesionalesValor() != null && dto.getMayorCostoProfesionalesValor().compareTo(BigDecimal.ZERO) > 0) {
                Double factorProfesionales = 1 + (dto.getMayorCostoProfesionalesValor().doubleValue() / 100);
                itemModificado |= consolidarProfesionalesEnItem(item, factorProfesionales);
                log.debug("�‍💼 Aplicando {}% a profesionales en item {}", dto.getMayorCostoProfesionalesValor(), item.getTipoProfesional());
            }
            // Si NO está seleccionado profesionales, mantener valores actuales (no modificar)
            
            // 2. MATERIALES - Solo si está seleccionado
            if (Boolean.TRUE.equals(dto.getAplicarMayoresCostosAMateriales()) && 
                dto.getMayorCostoMaterialesValor() != null && dto.getMayorCostoMaterialesValor().compareTo(BigDecimal.ZERO) > 0) {
                Double factorMateriales = 1 + (dto.getMayorCostoMaterialesValor().doubleValue() / 100);
                itemModificado |= consolidarMaterialesEnItem(item, factorMateriales);
                log.debug("🧱 Aplicando {}% a materiales en item {}", dto.getMayorCostoMaterialesValor(), item.getTipoProfesional());
            }
            // Si NO está seleccionado materiales, mantener valores actuales (no modificar)
            
            // 3. OTROS COSTOS - Solo si está seleccionado
            if (Boolean.TRUE.equals(dto.getAplicarMayoresCostosAOtrosCostos()) && 
                dto.getMayorCostoOtrosValor() != null && dto.getMayorCostoOtrosValor().compareTo(BigDecimal.ZERO) > 0) {
                Double factorOtrosCostos = 1 + (dto.getMayorCostoOtrosValor().doubleValue() / 100);
                itemModificado |= consolidarOtrosCostosEnItem(item, factorOtrosCostos);
                log.debug("📦 Aplicando {}% a otros costos en item {}", dto.getMayorCostoOtrosValor(), item.getTipoProfesional());
            }
            // Si NO está seleccionado otros costos, mantener valores actuales (no modificar)
            
            // 4. HONORARIOS - Solo si está seleccionado
            if (Boolean.TRUE.equals(dto.getAplicarMayoresCostosAHonorarios()) && 
                dto.getMayorCostoHonorariosValor() != null && dto.getMayorCostoHonorariosValor().compareTo(BigDecimal.ZERO) > 0) {
                Double factorHonorarios = 1 + (dto.getMayorCostoHonorariosValor().doubleValue() / 100);
                itemModificado |= consolidarHonorariosEnItem(item, factorHonorarios);
                log.debug("💼 Aplicando {}% a honorarios en item {}", dto.getMayorCostoHonorariosValor(), item.getTipoProfesional());
            }
            // Si NO está seleccionado honorarios, mantener valores actuales (no modificar)
            
            // Recalcular total del item solo si hubo modificaciones
            if (itemModificado) {
                recalcularTotalItem(item);
                itemCalculadoraRepository.save(item);
                itemsConsolidados++;
            }
        }
        
        log.info("✅ Consolidados {} items de calculadora", itemsConsolidados);
        
        // PASO 3: GUARDAR TODOS LOS ITEMS CONSOLIDADOS EXPLÍCITAMENTE
        log.info("💾 Guardando {} items consolidados en base de datos...", items.size());
        for (ItemCalculadoraPresupuesto item : items) {
            // Forzar persistencia de valores consolidados
            itemCalculadoraRepository.save(item);
            itemCalculadoraRepository.flush(); // Forzar commit inmediato
            
            log.debug("💾 Item {} guardado - Mano obra: {}, Materiales: {}, Total: {}", 
                item.getTipoProfesional(), 
                item.getSubtotalManoObra(), 
                item.getSubtotalMateriales(), 
                item.getTotal());
        }
        
        // PASO 4: Recalcular totales del presupuesto
        recalcularTotalesPresupuesto(presupuesto, dto);
        
        // PASO 5: GUARDAR PRESUPUESTO CON TOTALES CONSOLIDADOS
        repository.save(presupuesto);
        repository.flush(); // Forzar commit inmediato
        log.info("💾 Presupuesto principal guardado con totales consolidados");
        
        // PASO 6: NO RESETEAR CONFIGURACIÓN DURANTE GUARDADO NORMAL
        // El reseteo solo debe ocurrir al crear nueva versión, no en cada guardado
        log.info("💾 Valores consolidados PERSISTIDOS en BD - Configuración preservada para frontend");
        
        log.info("🎯 CONSOLIDACIÓN AUTOMÁTICA COMPLETADA - Sistema listo para nuevas aplicaciones acumulativas");
    }
    
    /**
     * Detecta si hay mayores costos configurados para aplicar
     */
    private boolean detectarMayoresCostosConfigurados(PresupuestoNoClienteRequestDTO dto) {
        return (dto.getValorMayorCosto() != null && dto.getValorMayorCosto().compareTo(BigDecimal.ZERO) > 0 && 
                Boolean.TRUE.equals(dto.getAplicarMayoresCostosATodos())) ||
               (Boolean.TRUE.equals(dto.getAplicarMayoresCostosAProfesionales()) ||
                Boolean.TRUE.equals(dto.getAplicarMayoresCostosAMateriales()) ||
                Boolean.TRUE.equals(dto.getAplicarMayoresCostosAOtrosCostos()) ||
                Boolean.TRUE.equals(dto.getAplicarMayoresCostosAHonorarios()));
    }
    
    /**
     * Obtiene el porcentaje de mayor costo a aplicar
     */
    private Double obtenerPorcentajeMayorCosto(PresupuestoNoClienteRequestDTO dto) {
        if (dto.getValorMayorCosto() != null) {
            return dto.getValorMayorCosto().doubleValue();
        }
        
        // Si no hay valor global, buscar el mayor de los específicos
        Double maxPorcentaje = 0.0;
        
        if (dto.getMayorCostoProfesionalesValor() != null) {
            maxPorcentaje = Math.max(maxPorcentaje, dto.getMayorCostoProfesionalesValor().doubleValue());
        }
        if (dto.getMayorCostoMaterialesValor() != null) {
            maxPorcentaje = Math.max(maxPorcentaje, dto.getMayorCostoMaterialesValor().doubleValue());
        }
        if (dto.getMayorCostoOtrosValor() != null) {
            maxPorcentaje = Math.max(maxPorcentaje, dto.getMayorCostoOtrosValor().doubleValue());
        }
        if (dto.getMayorCostoHonorariosValor() != null) {
            maxPorcentaje = Math.max(maxPorcentaje, dto.getMayorCostoHonorariosValor().doubleValue());
        }
        
        return maxPorcentaje;
    }
    
    /**
     * Consolida mayores costos en profesionales de un item - VERSIÓN REFORZADA
     */
    private boolean consolidarProfesionalesEnItem(ItemCalculadoraPresupuesto item, Double factorAumento) {
        boolean modificado = false;
        
        log.info("🔄 CONSOLIDANDO PROFESIONALES - Item: {}, Factor: {}", item.getTipoProfesional(), factorAumento);
        
        // 1. CONSOLIDAR SUBTOTAL MANO DE OBRA DEL ITEM
        if (item.getSubtotalManoObra() != null) {
            BigDecimal subtotalAnterior = item.getSubtotalManoObra();
            BigDecimal nuevoSubtotal = subtotalAnterior.multiply(BigDecimal.valueOf(factorAumento));
            item.setSubtotalManoObra(nuevoSubtotal);
            modificado = true;
            
            log.info("💼 ITEM - Subtotal mano obra: {} → {}", subtotalAnterior, nuevoSubtotal);
        }
        
        // 2. CONSOLIDAR IMPORTE JORNAL DEL ITEM (si no es modo manual)
        if (item.getImporteJornal() != null && !Boolean.TRUE.equals(item.getEsModoManual())) {
            BigDecimal importeAnterior = item.getImporteJornal();
            BigDecimal nuevoImporte = importeAnterior.multiply(BigDecimal.valueOf(factorAumento));
            item.setImporteJornal(nuevoImporte);
            modificado = true;
            
            log.info("💰 ITEM - Importe jornal: {} → {}", importeAnterior, nuevoImporte);
        }
        
        // 3. CONSOLIDAR PROFESIONALES INDIVIDUALES
        if (item.getProfesionales() != null && !item.getProfesionales().isEmpty()) {
            log.info("👥 Consolidando {} profesionales individuales", item.getProfesionales().size());
            
            for (ProfesionalCalculadora prof : item.getProfesionales()) {
                boolean profModificado = false;
                
                // Consolidar importe jornal del profesional
                if (prof.getImporteJornal() != null) {
                    BigDecimal importeAnterior = prof.getImporteJornal();
                    BigDecimal nuevoImporte = importeAnterior.multiply(BigDecimal.valueOf(factorAumento));
                    prof.setImporteJornal(nuevoImporte);
                    profModificado = true;
                    
                    log.info("  💰 Prof {}: importe {} → {}", prof.getNombre(), importeAnterior, nuevoImporte);
                }
                
                // Consolidar subtotal del profesional
                if (prof.getSubtotal() != null) {
                    BigDecimal subtotalAnterior = prof.getSubtotal();
                    BigDecimal nuevoSubtotal = subtotalAnterior.multiply(BigDecimal.valueOf(factorAumento));
                    prof.setSubtotal(nuevoSubtotal);
                    profModificado = true;
                    
                    log.info("  📊 Prof {}: subtotal {} → {}", prof.getNombre(), subtotalAnterior, nuevoSubtotal);
                }
                
                // GUARDAR INMEDIATAMENTE cada profesional consolidado
                if (profModificado) {
                    ProfesionalCalculadora profGuardado = profesionalCalculadoraRepository.save(prof);
                    profesionalCalculadoraRepository.flush();
                    log.info("  ✅ Prof {} GUARDADO en BD", prof.getNombre());
                    modificado = true;
                }
            }
        }
        
        return modificado;
    }
    
    /**
     * Consolida mayores costos en materiales de un item - VERSIÓN REFORZADA
     */
    private boolean consolidarMaterialesEnItem(ItemCalculadoraPresupuesto item, Double factorAumento) {
        boolean modificado = false;
        
        log.info("🔄 CONSOLIDANDO MATERIALES - Item: {}, Factor: {}", item.getTipoProfesional(), factorAumento);
        
        // 1. CONSOLIDAR SUBTOTAL MATERIALES DEL ITEM
        if (item.getSubtotalMateriales() != null) {
            BigDecimal subtotalAnterior = item.getSubtotalMateriales();
            BigDecimal nuevoSubtotal = subtotalAnterior.multiply(BigDecimal.valueOf(factorAumento));
            item.setSubtotalMateriales(nuevoSubtotal);
            modificado = true;
            
            log.info("🧱 ITEM - Subtotal materiales: {} → {}", subtotalAnterior, nuevoSubtotal);
        }
        
        // 2. CONSOLIDAR CAMPO MATERIALES LEGACY
        if (item.getMateriales() != null) {
            BigDecimal totalAnterior = item.getMateriales();
            BigDecimal nuevoTotal = totalAnterior.multiply(BigDecimal.valueOf(factorAumento));
            item.setMateriales(nuevoTotal);
            modificado = true;
            
            log.info("📦 ITEM - Materiales (legacy): {} → {}", totalAnterior, nuevoTotal);
        }
        
        // 3. CONSOLIDAR MATERIALES INDIVIDUALES
        if (item.getMaterialesLista() != null && !item.getMaterialesLista().isEmpty()) {
            log.info("🧱 Consolidando {} materiales individuales", item.getMaterialesLista().size());
            
            for (MaterialCalculadora mat : item.getMaterialesLista()) {
                boolean matModificado = false;
                
                // Consolidar precio del material
                if (mat.getPrecio() != null) {
                    BigDecimal precioAnterior = mat.getPrecio();
                    BigDecimal nuevoPrecio = precioAnterior.multiply(BigDecimal.valueOf(factorAumento));
                    mat.setPrecio(nuevoPrecio);
                    matModificado = true;
                    
                    log.info("  💰 Mat {}: precio {} → {}", mat.getNombre(), precioAnterior, nuevoPrecio);
                }
                
                // Consolidar subtotal del material
                if (mat.getSubtotal() != null) {
                    BigDecimal subtotalAnterior = mat.getSubtotal();
                    BigDecimal nuevoSubtotal = subtotalAnterior.multiply(BigDecimal.valueOf(factorAumento));
                    mat.setSubtotal(nuevoSubtotal);
                    matModificado = true;
                    
                    log.info("  📊 Mat {}: subtotal {} → {}", mat.getNombre(), subtotalAnterior, nuevoSubtotal);
                }
                
                // GUARDAR INMEDIATAMENTE cada material consolidado
                if (matModificado) {
                    MaterialCalculadora matGuardado = materialCalculadoraRepository.save(mat);
                    materialCalculadoraRepository.flush();
                    log.info("  ✅ Mat {} GUARDADO en BD", mat.getNombre());
                    modificado = true;
                }
            }
        }
        
        return modificado;
    }
    
    /**
     * Consolida mayores costos en otros costos de un item
     */
    /**
     * Consolida mayores costos en otros costos de un item - VERSIÓN REFORZADA
     */
    private boolean consolidarOtrosCostosEnItem(ItemCalculadoraPresupuesto item, Double factorAumento) {
        boolean modificado = false;
        
        log.info("🔄 CONSOLIDANDO OTROS COSTOS - Item: {}, Factor: {}", item.getTipoProfesional(), factorAumento);
        
        // 1. CONSOLIDAR SUBTOTAL GASTOS GENERALES DEL ITEM
        if (item.getSubtotalGastosGenerales() != null) {
            BigDecimal subtotalAnterior = item.getSubtotalGastosGenerales();
            BigDecimal nuevoSubtotal = subtotalAnterior.multiply(BigDecimal.valueOf(factorAumento));
            item.setSubtotalGastosGenerales(nuevoSubtotal);
            modificado = true;
            
            log.info("📦 ITEM - Subtotal gastos generales: {} → {}", subtotalAnterior, nuevoSubtotal);
        }
        
        // 2. CONSOLIDAR SUBTOTAL OTROS COSTOS DEL ITEM (si existe)
        // if (item.getSubtotalOtrosCostos() != null) {
        //     BigDecimal subtotalAnterior = item.getSubtotalOtrosCostos();
        //     BigDecimal nuevoSubtotal = subtotalAnterior.multiply(BigDecimal.valueOf(factorAumento));
        //     item.setSubtotalOtrosCostos(nuevoSubtotal);
        //     modificado = true;
        //     
        //     log.info("📦 ITEM - Subtotal otros costos: {} → {}", subtotalAnterior, nuevoSubtotal);
        // }
        
        // 3. CONSOLIDAR GASTOS GENERALES INDIVIDUALES
        if (item.getGastosGenerales() != null && !item.getGastosGenerales().isEmpty()) {
            log.info("📋 Consolidando {} gastos generales individuales", item.getGastosGenerales().size());
            
            for (PresupuestoGastoGeneral gasto : item.getGastosGenerales()) {
                boolean gastoModificado = false;
                
                // Consolidar precio unitario del gasto
                if (gasto.getPrecioUnitario() != null) {
                    BigDecimal precioAnterior = gasto.getPrecioUnitario();
                    BigDecimal nuevoPrecio = precioAnterior.multiply(BigDecimal.valueOf(factorAumento));
                    gasto.setPrecioUnitario(nuevoPrecio);
                    gastoModificado = true;
                    
                    log.info("  💰 Gasto {}: precio {} → {}", gasto.getDescripcion(), precioAnterior, nuevoPrecio);
                }
                
                // Consolidar subtotal del gasto
                if (gasto.getSubtotal() != null) {
                    BigDecimal subtotalAnterior = gasto.getSubtotal();
                    BigDecimal nuevoSubtotal = subtotalAnterior.multiply(BigDecimal.valueOf(factorAumento));
                    gasto.setSubtotal(nuevoSubtotal);
                    gastoModificado = true;
                    
                    log.info("  📊 Gasto {}: subtotal {} → {}", gasto.getDescripcion(), subtotalAnterior, nuevoSubtotal);
                }
                
                // GUARDAR INMEDIATAMENTE cada gasto consolidado
                if (gastoModificado) {
                    PresupuestoGastoGeneral gastoGuardado = gastoGeneralRepository.save(gasto);
                    gastoGeneralRepository.flush();
                    log.info("  ✅ Gasto {} GUARDADO en BD", gasto.getDescripcion());
                    modificado = true;
                }
            }
        }
        
        return modificado;
    }
    
    /**
     * Recalcula totales del presupuesto después de consolidar items
     */
    private void recalcularTotalesPresupuesto(PresupuestoNoCliente presupuesto, PresupuestoNoClienteRequestDTO dto) {
        log.info("🔄 Recalculando totales del presupuesto después de consolidación");
        
        // Obtener items actualizados desde la base de datos
        List<ItemCalculadoraPresupuesto> items = itemCalculadoraRepository.findByPresupuestoNoClienteId(presupuesto.getId());
        
        // Calcular nuevo total sumando todos los items consolidados
        Double totalItemsAntes = presupuesto.getTotalPresupuesto() != null ? presupuesto.getTotalPresupuesto().doubleValue() : 0.0;
        
        Double nuevoTotalPresupuesto = items.stream()
            .filter(item -> item.getTotal() != null)
            .mapToDouble(item -> item.getTotal().doubleValue())
            .sum();
        
        presupuesto.setTotalPresupuesto(BigDecimal.valueOf(nuevoTotalPresupuesto));
        
        log.info("� CONSOLIDACIÓN DE ITEMS CALCULADORA:");
        log.info("   📈 Total presupuesto: ${} → ${} (+${:.2f})", 
            totalItemsAntes, nuevoTotalPresupuesto, (nuevoTotalPresupuesto - totalItemsAntes));
        
        // Log detallado de cada item
        for (ItemCalculadoraPresupuesto item : items) {
            log.info("   📌 {}: ${}", item.getTipoProfesional(), 
                item.getTotal() != null ? item.getTotal() : BigDecimal.ZERO);
        }
        
        // Verificación de consistencia
        Double sumaItems = items.stream()
            .filter(item -> item.getTotal() != null)
            .mapToDouble(item -> item.getTotal().doubleValue())
            .sum();
        
        if (Math.abs(nuevoTotalPresupuesto - sumaItems) > 0.01) {
            log.warn("⚠️ INCONSISTENCIA: Total presupuesto ${} ≠ Suma items ${}", 
                nuevoTotalPresupuesto, sumaItems);
        } else {
            log.info("✅ CONSISTENCIA VERIFICADA: Total presupuesto = Suma items (${:.2f})", nuevoTotalPresupuesto);
        }
        
        // Aplicar mayores costos a honorarios si está configurado y consolidado
        if (Boolean.TRUE.equals(dto.getAplicarMayoresCostosAHonorarios()) && 
            dto.getMayorCostoHonorariosValor() != null && dto.getMayorCostoHonorariosValor().compareTo(BigDecimal.ZERO) > 0) {
            
            BigDecimal totalHonorariosActual = presupuesto.getTotalHonorariosCalculado();
            if (totalHonorariosActual != null) {
                Double factorHonorarios = 1 + (dto.getMayorCostoHonorariosValor().doubleValue() / 100);
                Double honorariosConMayoresCostos = totalHonorariosActual.doubleValue() * factorHonorarios;
                presupuesto.setTotalHonorariosCalculado(BigDecimal.valueOf(honorariosConMayoresCostos));
                log.info("💼 Honorarios actualizados: ${} → ${} (+{}%)", 
                    totalHonorariosActual, honorariosConMayoresCostos, dto.getMayorCostoHonorariosValor());
            }
        }
        
        // Recalcular total final
        Double totalHonorarios = presupuesto.getTotalHonorariosCalculado() != null ? presupuesto.getTotalHonorariosCalculado().doubleValue() : 0.0;
        Double totalFinal = nuevoTotalPresupuesto + totalHonorarios;
        // TODO: Activar cuando exista el método setTotalPresupuestoConHonorarios
        // presupuesto.setTotalPresupuestoConHonorarios(BigDecimal.valueOf(totalFinal));
        
        log.info("🎯 TOTALES FINALES CONSOLIDADOS:");
        log.info("   💰 Total presupuesto: ${:.2f}", nuevoTotalPresupuesto);
        log.info("   💼 Total honorarios: ${:.2f}", totalHonorarios);
        log.info("   🏆 TOTAL FINAL: ${:.2f}", totalFinal);
    }
    
    /**
     * Resetea la configuración de mayores costos después de consolidarla
     * CRÍTICO: RESETEO SELECTIVO - Solo resetea las categorías que fueron aplicadas
     * CONSERVA: Los valores de categorías no seleccionadas permanecen intactos
     */
    private void resetearConfiguracionMayoresCostosCompleta(PresupuestoNoCliente presupuesto, PresupuestoNoClienteRequestDTO dto, Double totalOriginal) {
        log.info("🧹 RESETEANDO SELECTIVO de configuración de mayores costos aplicados");
        
        // Guardar registro del último incremento aplicado (para auditoría)
        Double totalActual = presupuesto.getTotalPresupuesto() != null ? presupuesto.getTotalPresupuesto().doubleValue() : 0.0;
        Double incrementoAplicado = totalActual - totalOriginal;
        presupuesto.setTotalMayoresCostos(BigDecimal.valueOf(incrementoAplicado));
        
        // Resetear configuración de campo global (siempre)
        dto.setValorMayorCosto(null);
        dto.setTipoMayorCosto(null);
        dto.setAplicarMayoresCostosATodos(false);
        
        // RESETEO SELECTIVO POR CATEGORÍA - Solo resetear las que fueron aplicadas
        
        // 1. PROFESIONALES - Solo si fue aplicado
        if (Boolean.TRUE.equals(dto.getAplicarMayoresCostosAProfesionales())) {
            log.info("🔄 Reseteando configuración PROFESIONALES (fue aplicada)");
            dto.setAplicarMayoresCostosAProfesionales(false);
            dto.setMayorCostoProfesionalesValor(null);
            presupuesto.setMayorCostoProfesionalesActivo(false);
            presupuesto.setMayorCostoProfesionalesValor(null);
            presupuesto.setMayorCostoProfesionalesTipo(null);
            presupuesto.setAplicarMayoresCostosAProfesionales(false);
        } else {
            log.info("💾 CONSERVANDO configuración PROFESIONALES (no fue aplicada)");
            // No tocar los valores existentes en BD para profesionales
        }
        
        // 2. MATERIALES - Solo si fue aplicado
        if (Boolean.TRUE.equals(dto.getAplicarMayoresCostosAMateriales())) {
            log.info("🔄 Reseteando configuración MATERIALES (fue aplicada)");
            dto.setAplicarMayoresCostosAMateriales(false);
            dto.setMayorCostoMaterialesValor(null);
            presupuesto.setMayorCostoMaterialesActivo(false);
            presupuesto.setMayorCostoMaterialesValor(null);
            presupuesto.setMayorCostoMaterialesTipo(null);
            presupuesto.setAplicarMayoresCostosAMateriales(false);
        } else {
            log.info("💾 CONSERVANDO configuración MATERIALES (no fue aplicada)");
            // No tocar los valores existentes en BD para materiales
        }
        
        // 3. OTROS COSTOS - Solo si fue aplicado
        if (Boolean.TRUE.equals(dto.getAplicarMayoresCostosAOtrosCostos())) {
            log.info("🔄 Reseteando configuración OTROS COSTOS (fue aplicada)");
            dto.setAplicarMayoresCostosAOtrosCostos(false);
            dto.setMayorCostoOtrosValor(null);
            presupuesto.setMayorCostoOtrosActivo(false);
            presupuesto.setMayorCostoOtrosValor(null);
            presupuesto.setMayorCostoOtrosTipo(null);
            presupuesto.setAplicarMayoresCostosAOtrosCostos(false);
        } else {
            log.info("💾 CONSERVANDO configuración OTROS COSTOS (no fue aplicada)");
            // No tocar los valores existentes en BD para otros costos
        }
        
        // 4. HONORARIOS - Solo si fue aplicado
        if (Boolean.TRUE.equals(dto.getAplicarMayoresCostosAHonorarios())) {
            log.info("🔄 Reseteando configuración HONORARIOS (fue aplicada)");
            dto.setAplicarMayoresCostosAHonorarios(false);
            dto.setMayorCostoHonorariosValor(null);
            presupuesto.setMayorCostoHonorariosActivo(false);
            presupuesto.setMayorCostoHonorariosValor(null);
            presupuesto.setMayorCostoHonorariosTipo(null);
            presupuesto.setAplicarMayoresCostosAHonorarios(false);
        } else {
            log.info("💾 CONSERVANDO configuración HONORARIOS (no fue aplicada)");
            // No tocar los valores existentes en BD para honorarios
        }
        
        // Configuración general (resetear siempre para evitar conflictos)
        dto.setMayorCostoConfiguracionValor(null);
        presupuesto.setMayorCostoConfiguracionActivo(false);
        presupuesto.setMayorCostoConfiguracionValor(null);
        presupuesto.setMayorCostoConfiguracionTipo(null);
        presupuesto.setAplicarMayoresCostosAConfiguracion(false);
        presupuesto.setAplicarMayoresCostosAMateriales(false);
        presupuesto.setAplicarMayoresCostosAOtrosCostos(false);
        presupuesto.setAplicarMayoresCostosAHonorarios(false);
        presupuesto.setAplicarMayoresCostosAConfiguracion(false);
        
        // Resetear configuración de aceptación
        presupuesto.setConfiguracionMayoresCostosAceptada(false);
        dto.setConfiguracionMayoresCostosAceptada(false);
        
        log.info("✅ Configuración COMPLETAMENTE reseteada - Incremento aplicado: ${}", incrementoAplicado);
        log.info("🔄 Sistema listo para NUEVAS aplicaciones acumulativas de mayores costos");
    }
    
    /**
     * Consolida mayores costos en subtotales del item (mano de obra, materiales, gastos generales).
     */
    private void consolidarSubtotales(ItemCalculadoraPresupuesto item, BigDecimal porcentaje, Map<String, BigDecimal> configuracion) {
        BigDecimal factor = BigDecimal.ONE.add(porcentaje.divide(new BigDecimal("100")));
        
        // Subtotal mano de obra (profesionales)
        if (item.getSubtotalManoObra() != null && configuracion.containsKey("PROFESIONALES")) {
            BigDecimal porcentajeProfesionales = configuracion.get("PROFESIONALES");
            BigDecimal factorProfesionales = BigDecimal.ONE.add(porcentajeProfesionales.divide(new BigDecimal("100")));
            item.setSubtotalManoObra(item.getSubtotalManoObra().multiply(factorProfesionales));
        }
        
        // Subtotal materiales
        if (item.getSubtotalMateriales() != null && configuracion.containsKey("MATERIALES")) {
            BigDecimal porcentajeMateriales = configuracion.get("MATERIALES");
            BigDecimal factorMateriales = BigDecimal.ONE.add(porcentajeMateriales.divide(new BigDecimal("100")));
            item.setSubtotalMateriales(item.getSubtotalMateriales().multiply(factorMateriales));
        }
        
        // Subtotal gastos generales
        if (item.getSubtotalGastosGenerales() != null && configuracion.containsKey("CONFIGURACION")) {
            BigDecimal porcentajeConfiguracion = configuracion.get("CONFIGURACION");
            BigDecimal factorConfiguracion = BigDecimal.ONE.add(porcentajeConfiguracion.divide(new BigDecimal("100")));
            item.setSubtotalGastosGenerales(item.getSubtotalGastosGenerales().multiply(factorConfiguracion));
        }
        
        // Campo materiales (legacy)
        if (item.getMateriales() != null && configuracion.containsKey("MATERIALES")) {
            BigDecimal porcentajeMateriales = configuracion.get("MATERIALES");
            BigDecimal factorMateriales = BigDecimal.ONE.add(porcentajeMateriales.divide(new BigDecimal("100")));
            item.setMateriales(item.getMateriales().multiply(factorMateriales));
        }
    }
    
    /**
     * Consolida mayores costos en profesionales individuales del item.
     */
    private void consolidarProfesionalesIndividuales(ItemCalculadoraPresupuesto item, BigDecimal porcentaje, Map<String, BigDecimal> configuracion) {
        if (item.getProfesionales() == null || item.getProfesionales().isEmpty()) {
            return;
        }
        
        BigDecimal porcentajeProfesionales = configuracion.get("PROFESIONALES");
        if (porcentajeProfesionales == null || porcentajeProfesionales.compareTo(BigDecimal.ZERO) <= 0) {
            return;
        }
        
        BigDecimal factor = BigDecimal.ONE.add(porcentajeProfesionales.divide(new BigDecimal("100")));
        
        for (ProfesionalCalculadora profesional : item.getProfesionales()) {
            // Consolidar importe jornal
            if (profesional.getImporteJornal() != null) {
                profesional.setImporteJornal(profesional.getImporteJornal().multiply(factor));
            }
            
            // Consolidar subtotal
            if (profesional.getSubtotal() != null) {
                profesional.setSubtotal(profesional.getSubtotal().multiply(factor));
            }
            
            // Guardar profesional actualizado
            profesionalCalculadoraRepository.save(profesional);
        }
        
        log.debug("✅ Consolidados {} profesionales del item {} con factor {}", 
            item.getProfesionales().size(), item.getTipoProfesional(), factor);
    }
    
    /**
     * Consolida mayores costos en materiales individuales del item.
     */
    private void consolidarMaterialesIndividuales(ItemCalculadoraPresupuesto item, BigDecimal porcentaje, Map<String, BigDecimal> configuracion) {
        if (item.getMaterialesLista() == null || item.getMaterialesLista().isEmpty()) {
            return;
        }
        
        BigDecimal porcentajeMateriales = configuracion.get("MATERIALES");
        if (porcentajeMateriales == null || porcentajeMateriales.compareTo(BigDecimal.ZERO) <= 0) {
            return;
        }
        
        BigDecimal factor = BigDecimal.ONE.add(porcentajeMateriales.divide(new BigDecimal("100")));
        
        for (MaterialCalculadora material : item.getMaterialesLista()) {
            // Consolidar precio unitario
            if (material.getPrecio() != null) {
                material.setPrecio(material.getPrecio().multiply(factor));
            }
            
            // Consolidar subtotal
            if (material.getSubtotal() != null) {
                material.setSubtotal(material.getSubtotal().multiply(factor));
            }
            
            // Guardar material actualizado
            materialCalculadoraRepository.save(material);
        }
        
        log.debug("✅ Consolidados {} materiales del item {} con factor {}", 
            item.getMaterialesLista().size(), item.getTipoProfesional(), factor);
    }
    
    /**
     * Actualiza los totales globales del presupuesto después de la consolidación.
     */
    private void actualizarTotalesGlobalesPresupuesto(PresupuestoNoCliente presupuesto, BigDecimal incrementoTotal) {
        // Recalcular totalPresupuesto sumando los nuevos totales de los items
        List<ItemCalculadoraPresupuesto> items = itemCalculadoraRepository.findByPresupuestoNoClienteId(presupuesto.getId());
        BigDecimal nuevoTotalPresupuesto = items.stream()
            .filter(item -> item.getTotal() != null)
            .map(ItemCalculadoraPresupuesto::getTotal)
            .reduce(BigDecimal.ZERO, BigDecimal::add);
        
        // Actualizar total presupuesto
        if (presupuesto.getTotalPresupuesto() != null) {
            presupuesto.setTotalPresupuesto(nuevoTotalPresupuesto);
        }
        
        // Aplicar mayores costos a honorarios si está configurado
        if (Boolean.TRUE.equals(presupuesto.getMayorCostoHonorariosActivo()) && 
            presupuesto.getMayorCostoHonorariosValor() != null &&
            presupuesto.getMayorCostoHonorariosValor().compareTo(BigDecimal.ZERO) > 0) {
            
            BigDecimal porcentajeHonorarios = presupuesto.getMayorCostoHonorariosValor();
            BigDecimal factorHonorarios = BigDecimal.ONE.add(porcentajeHonorarios.divide(new BigDecimal("100")));
            
            if (presupuesto.getTotalHonorariosCalculado() != null) {
                Double honorariosConMC = presupuesto.getTotalHonorariosCalculado().doubleValue() * factorHonorarios.doubleValue();
                presupuesto.setTotalHonorariosCalculado(BigDecimal.valueOf(honorariosConMC));
            }
        }
        
        // Calcular total final con honorarios
        Double totalPresupuesto = presupuesto.getTotalPresupuesto() != null ? presupuesto.getTotalPresupuesto().doubleValue() : 0.0;
        Double totalHonorarios = presupuesto.getTotalHonorariosCalculado() != null ? presupuesto.getTotalHonorariosCalculado().doubleValue() : 0.0;
        // TODO: Activar cuando exista el método setTotalPresupuestoConHonorarios
        // presupuesto.setTotalPresupuestoConHonorarios(BigDecimal.valueOf(totalPresupuesto + totalHonorarios));
        
        log.info("🔢 Totales globales actualizados: Presupuesto=${}, Honorarios=${}, Total=PENDIENTE", 
            totalPresupuesto, totalHonorarios);
    }
    
    /**
     * Resetea la configuración de mayores costos después de consolidarla,
     * permitiendo aplicaciones acumulativas futuras.
     */
    private void resetearConfiguracionMayoresCostos(PresupuestoNoCliente presupuesto, BigDecimal incrementoTotal) {
        log.info("🧹 Reseteando configuración de mayores costos para permitir nuevas aplicaciones acumulativas");
        
        // Guardar el último incremento aplicado (para referencia)
        presupuesto.setTotalMayoresCostos(incrementoTotal);
        
        // RESETEAR todos los campos de configuración de mayores costos
        presupuesto.setMayorCostoProfesionalesActivo(false);
        presupuesto.setMayorCostoProfesionalesValor(null);
        presupuesto.setMayorCostoProfesionalesTipo(null);
        
        presupuesto.setMayorCostoMaterialesActivo(false);
        presupuesto.setMayorCostoMaterialesValor(null);
        presupuesto.setMayorCostoMaterialesTipo(null);
        
        presupuesto.setMayorCostoOtrosActivo(false);
        presupuesto.setMayorCostoOtrosValor(null);
        presupuesto.setMayorCostoOtrosTipo(null);
        
        presupuesto.setMayorCostoHonorariosActivo(false);
        presupuesto.setMayorCostoHonorariosValor(null);
        presupuesto.setMayorCostoHonorariosTipo(null);
        
        presupuesto.setMayorCostoConfiguracionActivo(false);
        presupuesto.setMayorCostoConfiguracionValor(null);
        presupuesto.setMayorCostoConfiguracionTipo(null);
        
        // RESETEAR flags de aplicación
        presupuesto.setAplicarMayoresCostosAProfesionales(false);
        presupuesto.setAplicarMayoresCostosAMateriales(false);
        presupuesto.setAplicarMayoresCostosAOtrosCostos(false);
        presupuesto.setAplicarMayoresCostosAHonorarios(false);
        presupuesto.setAplicarMayoresCostosAConfiguracion(false);
        
        // RESETEAR configuración de aceptación (lista para nueva configuración)
        presupuesto.setConfiguracionMayoresCostosAceptada(false);
        
        log.info("✅ Configuración de mayores costos COMPLETAMENTE reseteada para presupuesto {}", presupuesto.getId());
        log.info("🔄 El presupuesto está listo para recibir NUEVAS aplicaciones de mayores costos de forma ACUMULATIVA");
    }
    
    /**
     * Obtiene la configuración de mayores costos por categoría.
     * 
     * @param presupuesto Presupuesto con configuración
     * @return Mapa de categoría → porcentaje de mayor costo
     */
    private Map<String, BigDecimal> obtenerMayoresCostosPorCategoria(PresupuestoNoCliente presupuesto) {
        Map<String, BigDecimal> mayoresCostos = new HashMap<>();
        
        // Profesionales
        if (Boolean.TRUE.equals(presupuesto.getMayorCostoProfesionalesActivo()) && 
            presupuesto.getMayorCostoProfesionalesValor() != null && 
            presupuesto.getMayorCostoProfesionalesValor().compareTo(BigDecimal.ZERO) > 0) {
            mayoresCostos.put("PROFESIONALES", presupuesto.getMayorCostoProfesionalesValor());
        }
        
        // Materiales
        if (Boolean.TRUE.equals(presupuesto.getMayorCostoMaterialesActivo()) && 
            presupuesto.getMayorCostoMaterialesValor() != null && 
            presupuesto.getMayorCostoMaterialesValor().compareTo(BigDecimal.ZERO) > 0) {
            mayoresCostos.put("MATERIALES", presupuesto.getMayorCostoMaterialesValor());
        }
        
        // Otros costos
        if (Boolean.TRUE.equals(presupuesto.getMayorCostoOtrosActivo()) && 
            presupuesto.getMayorCostoOtrosValor() != null && 
            presupuesto.getMayorCostoOtrosValor().compareTo(BigDecimal.ZERO) > 0) {
            mayoresCostos.put("OTROS_COSTOS", presupuesto.getMayorCostoOtrosValor());
        }
        
        // Honorarios
        if (Boolean.TRUE.equals(presupuesto.getMayorCostoHonorariosActivo()) && 
            presupuesto.getMayorCostoHonorariosValor() != null && 
            presupuesto.getMayorCostoHonorariosValor().compareTo(BigDecimal.ZERO) > 0) {
            mayoresCostos.put("HONORARIOS", presupuesto.getMayorCostoHonorariosValor());
        }
        
        // Configuración
        if (Boolean.TRUE.equals(presupuesto.getMayorCostoConfiguracionActivo()) && 
            presupuesto.getMayorCostoConfiguracionValor() != null && 
            presupuesto.getMayorCostoConfiguracionValor().compareTo(BigDecimal.ZERO) > 0) {
            mayoresCostos.put("CONFIGURACION", presupuesto.getMayorCostoConfiguracionValor());
        }
        
        return mayoresCostos;
    }
    
    /**
     * Determina el porcentaje de mayor costo que se debe aplicar a un item específico
     * basado en su categoría.
     * 
     * @param item Item de calculadora
     * @param mayoresCostosPorCategoria Configuración de mayores costos
     * @return Porcentaje a aplicar (puede ser null si no aplica ninguno)
     */
    private BigDecimal determinarPorcentajeMayorCostoParaItem(ItemCalculadoraPresupuesto item, 
                                                             Map<String, BigDecimal> mayoresCostosPorCategoria) {
        
        // Si es gasto general, aplicar configuración
        if (Boolean.TRUE.equals(item.getEsGastoGeneral())) {
            return mayoresCostosPorCategoria.get("CONFIGURACION");
        }
        
        // Para items normales, determinar categoría basada en contenido
        BigDecimal subtotalManoObra = item.getSubtotalManoObra() != null ? item.getSubtotalManoObra() : BigDecimal.ZERO;
        BigDecimal subtotalMateriales = item.getSubtotalMateriales() != null ? item.getSubtotalMateriales() : BigDecimal.ZERO;
        
        // Si tiene principalmente mano de obra (profesionales)
        if (subtotalManoObra.compareTo(BigDecimal.ZERO) > 0 && 
            subtotalManoObra.compareTo(subtotalMateriales) >= 0) {
            return mayoresCostosPorCategoria.get("PROFESIONALES");
        }
        
        // Si tiene principalmente materiales
        if (subtotalMateriales.compareTo(BigDecimal.ZERO) > 0) {
            return mayoresCostosPorCategoria.get("MATERIALES");
        }
        
        // Para items con total manual o sin clasificación clara, aplicar "otros costos"
        if (Boolean.TRUE.equals(item.getEsModoManual()) || item.getTotalManual() != null) {
            return mayoresCostosPorCategoria.get("OTROS_COSTOS");
        }
        
        // Por defecto, aplicar configuración de profesionales si está disponible
        return mayoresCostosPorCategoria.get("PROFESIONALES");
    }
    
    /**
     * Limpia la configuración de mayores costos después de consolidarla en los items.
     * 
     * @param presupuesto Presupuesto a limpiar
     */
    private void limpiarConfiguracionMayoresCostos(PresupuestoNoCliente presupuesto) {
        // Usar el método completo de reseteo
        resetearConfiguracionMayoresCostos(presupuesto, BigDecimal.ZERO);
    }
    
    /**
     * Verifica si el presupuesto tiene configuración de mayores costos activa
     * (antes de ser consolidada).
     * 
     * @param presupuesto Presupuesto a verificar
     * @return true si tiene configuración activa
     */
    private boolean tieneConfiguracionMayoresCostosActiva(PresupuestoNoCliente presupuesto) {
        return (Boolean.TRUE.equals(presupuesto.getMayorCostoProfesionalesActivo()) && presupuesto.getMayorCostoProfesionalesValor() != null && presupuesto.getMayorCostoProfesionalesValor().compareTo(BigDecimal.ZERO) > 0) ||
               (Boolean.TRUE.equals(presupuesto.getMayorCostoMaterialesActivo()) && presupuesto.getMayorCostoMaterialesValor() != null && presupuesto.getMayorCostoMaterialesValor().compareTo(BigDecimal.ZERO) > 0) ||
               (Boolean.TRUE.equals(presupuesto.getMayorCostoOtrosActivo()) && presupuesto.getMayorCostoOtrosValor() != null && presupuesto.getMayorCostoOtrosValor().compareTo(BigDecimal.ZERO) > 0) ||
               (Boolean.TRUE.equals(presupuesto.getMayorCostoHonorariosActivo()) && presupuesto.getMayorCostoHonorariosValor() != null && presupuesto.getMayorCostoHonorariosValor().compareTo(BigDecimal.ZERO) > 0) ||
               (Boolean.TRUE.equals(presupuesto.getMayorCostoConfiguracionActivo()) && presupuesto.getMayorCostoConfiguracionValor() != null && presupuesto.getMayorCostoConfiguracionValor().compareTo(BigDecimal.ZERO) > 0);
    }
    
    /**
     * Consolida mayores costos específicamente en honorarios del item.
     * CONSERVA valores existentes si no se modifica honorarios.
     */
    /**
     * Consolida mayores costos en honorarios de un item - VERSIÓN REFORZADA
     */
    private boolean consolidarHonorariosEnItem(ItemCalculadoraPresupuesto item, Double factorHonorarios) {
        boolean modificado = false;
        
        log.info("🔄 CONSOLIDANDO HONORARIOS - Item: {}, Factor: {}", item.getTipoProfesional(), factorHonorarios);
        
        // 1. CONSOLIDAR HONORARIOS DEL ITEM
        // if (item.getHonorarios() != null) {
        //     BigDecimal honorariosAnterior = item.getHonorarios();
        //     BigDecimal nuevosHonorarios = honorariosAnterior.multiply(BigDecimal.valueOf(factorHonorarios));
        //     item.setHonorarios(nuevosHonorarios);
        //     modificado = true;
        //     
        //     log.info("💼 ITEM - Honorarios: {} → {}", honorariosAnterior, nuevosHonorarios);
        // }
        
        // 2. CONSOLIDAR SUBTOTAL HONORARIOS (si existe campo separado)
        // if (item.getSubtotalHonorarios() != null) {
        //     BigDecimal subtotalAnterior = item.getSubtotalHonorarios();
        //     BigDecimal nuevoSubtotal = subtotalAnterior.multiply(BigDecimal.valueOf(factorHonorarios));
        //     item.setSubtotalHonorarios(nuevoSubtotal);
        //     modificado = true;
        //     
        //     log.info("💼 ITEM - Subtotal honorarios: {} → {}", subtotalAnterior, nuevoSubtotal);
        // }
        
        // 3. PERSISTIR CAMBIOS SI HUBO MODIFICACIONES
        if (modificado) {
            // Los honorarios son parte del item, se guardarán cuando se guarde el item
            log.info("✅ Honorarios CONSOLIDADOS para item {}", item.getTipoProfesional());
        } else {
            log.info("ℹ️ Item {} no tiene honorarios para consolidar", item.getTipoProfesional());
        }
        
        return modificado;
    }
    
    /**
     * Recalcula el total del item basado en sus subtotales consolidados.
     * CONSERVATIVO: Solo recalcula si hay subtotales válidos.
     */
    private void recalcularTotalItem(ItemCalculadoraPresupuesto item) {
        BigDecimal nuevoTotal = BigDecimal.ZERO;
        boolean haySubtotales = false;
        
        BigDecimal totalAnterior = item.getTotal() != null ? item.getTotal() : BigDecimal.ZERO;
        
        // Sumar subtotales que existan
        if (item.getSubtotalManoObra() != null) {
            nuevoTotal = nuevoTotal.add(item.getSubtotalManoObra());
            haySubtotales = true;
            log.debug("  ➕ Mano obra: {}", item.getSubtotalManoObra());
        }
        
        if (item.getSubtotalMateriales() != null) {
            nuevoTotal = nuevoTotal.add(item.getSubtotalMateriales());
            haySubtotales = true;
            log.debug("  ➕ Materiales: {}", item.getSubtotalMateriales());
        }
        
        if (item.getSubtotalGastosGenerales() != null) {
            nuevoTotal = nuevoTotal.add(item.getSubtotalGastosGenerales());
            haySubtotales = true;
            log.debug("  ➕ Gastos generales: {}", item.getSubtotalGastosGenerales());
        }
        
        // if (item.getSubtotalOtrosCostos() != null) {
        //     nuevoTotal = nuevoTotal.add(item.getSubtotalOtrosCostos());
        //     haySubtotales = true;
        //     log.debug("  ➕ Otros costos: {}", item.getSubtotalOtrosCostos());
        // }
        
        // if (item.getHonorarios() != null) {
        //     nuevoTotal = nuevoTotal.add(item.getHonorarios());
        //     haySubtotales = true;
        //     log.debug("  ➕ Honorarios: {}", item.getHonorarios());
        // }
        
        // Solo actualizar el total si hay subtotales válidos
        if (haySubtotales) {
            item.setTotal(nuevoTotal);
            
            log.debug("🧮 Item {}: Total recalculado {} → {}", 
                item.getTipoProfesional(), totalAnterior, nuevoTotal);
        } else {
            log.debug("⚠️ Item {}: No hay subtotales para recalcular", item.getTipoProfesional());
        }
    }

    /**
     * Método auxiliar para copiar items de calculadora de un presupuesto base
     * IMPORTANTE: Maneja valores null correctamente - no los convierte a 0
     */
    private void copiarItemsCalculadoraDePresupuestoBase(Long presupuestoId, Long presupuestoBaseId) {
        try {
            log.info("🔄 Iniciando copia de items calculadora desde presupuesto base ID: {} hacia presupuesto ID: {}", 
                presupuestoBaseId, presupuestoId);
            
            // Obtener items del presupuesto base
            List<ItemCalculadoraPresupuesto> itemsBase = itemCalculadoraRepository.findByPresupuestoNoClienteId(presupuestoBaseId);
            
            if (itemsBase.isEmpty()) {
                log.warn("⚠️ No se encontraron items calculadora en el presupuesto base ID: {}", presupuestoBaseId);
                return;
            }
            
            log.info("📊 Encontrados {} items calculadora para copiar", itemsBase.size());
            
            // Obtener el presupuesto destino
            PresupuestoNoCliente presupuestoDestino = repository.findById(presupuestoId)
                .orElseThrow(() -> new RuntimeException("Presupuesto destino no encontrado: " + presupuestoId));
            
            for (ItemCalculadoraPresupuesto itemBase : itemsBase) {
                // Crear nuevo item copiando TODOS los valores consolidados
                ItemCalculadoraPresupuesto nuevoItem = new ItemCalculadoraPresupuesto();
                
                // Asignar al nuevo presupuesto  
                nuevoItem.setPresupuestoNoCliente(presupuestoDestino);
                nuevoItem.setEmpresa(presupuestoDestino.getEmpresa());
                
                // ========== COPIAR DATOS BÁSICOS ==========
                nuevoItem.setTipoProfesional(itemBase.getTipoProfesional());
                nuevoItem.setCantidadJornales(itemBase.getCantidadJornales());
                nuevoItem.setImporteJornal(itemBase.getImporteJornal());
                nuevoItem.setMateriales(itemBase.getMateriales());
                nuevoItem.setTotalManual(itemBase.getTotalManual());
                nuevoItem.setEsModoManual(itemBase.getEsModoManual());
                nuevoItem.setEsGastoGeneral(itemBase.getEsGastoGeneral());
                nuevoItem.setDescripcionGastosGenerales(itemBase.getDescripcionGastosGenerales());
                nuevoItem.setObservacionesGastosGenerales(itemBase.getObservacionesGastosGenerales());
                
                // ========== COPIAR SUBTOTALES CONSOLIDADOS (CRÍTICO) ==========
                // Estos valores YA INCLUYEN los mayores costos consolidados
                nuevoItem.setSubtotalManoObra(itemBase.getSubtotalManoObra()); // VALORES CONSOLIDADOS
                nuevoItem.setSubtotalMateriales(itemBase.getSubtotalMateriales()); // VALORES CONSOLIDADOS  
                nuevoItem.setSubtotalGastosGenerales(itemBase.getSubtotalGastosGenerales()); // VALORES CONSOLIDADOS
                nuevoItem.setTotal(itemBase.getTotal()); // TOTAL CONSOLIDADO
                
                log.debug("📋 Copiando item {} con valores CONSOLIDADOS:", itemBase.getTipoProfesional());
                log.debug("   💼 Subtotal mano obra: {}", itemBase.getSubtotalManoObra());
                log.debug("   🧱 Subtotal materiales: {}", itemBase.getSubtotalMateriales());
                log.debug("   📦 Subtotal gastos generales: {}", itemBase.getSubtotalGastosGenerales());
                log.debug("   🏆 TOTAL: {}", itemBase.getTotal());
                
                // Guardar el nuevo item
                ItemCalculadoraPresupuesto itemGuardado = itemCalculadoraRepository.save(nuevoItem);
                
                // ========== COPIAR PROFESIONALES INDIVIDUALES ==========
                if (itemBase.getProfesionales() != null && !itemBase.getProfesionales().isEmpty()) {
                    log.debug("👥 Copiando {} profesionales para item {}", 
                        itemBase.getProfesionales().size(), itemBase.getTipoProfesional());
                    
                    for (ProfesionalCalculadora profBase : itemBase.getProfesionales()) {
                        ProfesionalCalculadora nuevoProf = new ProfesionalCalculadora();
                        nuevoProf.setItemCalculadora(itemGuardado);
                        nuevoProf.setEmpresa(presupuestoDestino.getEmpresa());
                        nuevoProf.setFrontendId(profBase.getFrontendId());
                        nuevoProf.setTipo(profBase.getTipo());
                        nuevoProf.setNombre(profBase.getNombre());
                        nuevoProf.setTelefono(profBase.getTelefono());
                        nuevoProf.setUnidad(profBase.getUnidad());
                        nuevoProf.setCantidadJornales(profBase.getCantidadJornales());
                        nuevoProf.setImporteJornal(profBase.getImporteJornal()); // VALOR CONSOLIDADO
                        nuevoProf.setSubtotal(profBase.getSubtotal()); // VALOR CONSOLIDADO
                        nuevoProf.setSinCantidad(profBase.getSinCantidad());
                        nuevoProf.setSinImporte(profBase.getSinImporte());
                        
                        profesionalCalculadoraRepository.save(nuevoProf);
                    }
                }
                
                // ========== COPIAR MATERIALES INDIVIDUALES ==========
                if (itemBase.getMaterialesLista() != null && !itemBase.getMaterialesLista().isEmpty()) {
                    log.debug("🧱 Copiando {} materiales para item {}", 
                        itemBase.getMaterialesLista().size(), itemBase.getTipoProfesional());
                    
                    for (MaterialCalculadora matBase : itemBase.getMaterialesLista()) {
                        MaterialCalculadora nuevoMat = new MaterialCalculadora();
                        nuevoMat.setItemCalculadora(itemGuardado);
                        nuevoMat.setEmpresa(presupuestoDestino.getEmpresa());
                        nuevoMat.setFrontendId(matBase.getFrontendId());
                        nuevoMat.setNombre(matBase.getNombre());
                        nuevoMat.setDescripcion(matBase.getDescripcion());
                        nuevoMat.setUnidad(matBase.getUnidad());
                        nuevoMat.setCantidad(matBase.getCantidad());
                        nuevoMat.setPrecio(matBase.getPrecio()); // VALOR CONSOLIDADO
                        nuevoMat.setSubtotal(matBase.getSubtotal()); // VALOR CONSOLIDADO
                        
                        materialCalculadoraRepository.save(nuevoMat);
                    }
                }
                
                // ========== COPIAR GASTOS GENERALES ==========
                if (Boolean.TRUE.equals(itemBase.getEsGastoGeneral()) && 
                    itemBase.getGastosGenerales() != null && !itemBase.getGastosGenerales().isEmpty()) {
                    
                    log.debug("📋 Copiando {} gastos generales para item {}", 
                        itemBase.getGastosGenerales().size(), itemBase.getTipoProfesional());
                    
                    for (PresupuestoGastoGeneral gastoBase : itemBase.getGastosGenerales()) {
                        PresupuestoGastoGeneral nuevoGasto = new PresupuestoGastoGeneral();
                        nuevoGasto.setItemCalculadora(itemGuardado);
                        nuevoGasto.setEmpresa(presupuestoDestino.getEmpresa());
                        nuevoGasto.setDescripcion(gastoBase.getDescripcion());
                        nuevoGasto.setCantidad(gastoBase.getCantidad());
                        nuevoGasto.setPrecioUnitario(gastoBase.getPrecioUnitario()); // VALOR CONSOLIDADO
                        nuevoGasto.setSubtotal(gastoBase.getSubtotal()); // VALOR CONSOLIDADO
                        nuevoGasto.setSinCantidad(gastoBase.getSinCantidad());
                        nuevoGasto.setSinPrecio(gastoBase.getSinPrecio());
                        nuevoGasto.setOrden(gastoBase.getOrden());
                        
                        gastoGeneralRepository.save(nuevoGasto);
                    }
                }
                
                log.info("✅ Item {} copiado exitosamente con VALORES CONSOLIDADOS: Total = {}", 
                    itemGuardado.getTipoProfesional(), itemGuardado.getTotal());
            }
            
            log.info("✅ Copia de items calculadora completada exitosamente. {} items copiados con valores ACTUALES", itemsBase.size());
            
        } catch (Exception e) {
            log.error("❌ Error al copiar items calculadora: {}", e.getMessage(), e);
            throw new RuntimeException("Error al copiar items calculadora: " + e.getMessage(), e);
        }
    }
}
