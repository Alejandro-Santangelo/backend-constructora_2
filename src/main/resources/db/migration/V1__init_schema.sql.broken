--
-- Name: presupuesto_no_cliente; Type: TABLE; Schema: public; Owner: -
--

CREATE TABLE public.presupuesto_no_cliente (
    fecha_creacion date,
    fecha_emision date NOT NULL,
    fecha_probable_inicio date,
    honorario_direccion_importe double precision,
    honorario_direccion_porcentaje double precision,
    honorario_direccion_valor_fijo double precision,
    honorarios_aplicar_a_todos boolean,
    honorarios_configuracion_presupuesto_activo boolean,
    honorarios_configuracion_presupuesto_valor numeric(10,2),
    honorarios_jornales_activo boolean,
    honorarios_jornales_valor numeric(15,2),
    honorarios_materiales_activo boolean,
    honorarios_materiales_valor numeric(15,2),
    honorarios_otros_costos_activo boolean,
    honorarios_otros_costos_valor numeric(15,2),
    honorarios_profesionales_activo boolean,
    honorarios_profesionales_valor numeric(15,2),
    honorarios_valor_general numeric(15,2),
    mayores_costos_aplicar_valor_general boolean,
    mayores_costos_configuracion_presupuesto_activo boolean,
    mayores_costos_configuracion_presupuesto_valor double precision,
    mayores_costos_general_importado boolean,
    mayores_costos_honorarios_activo boolean,
    mayores_costos_honorarios_valor double precision,
    mayores_costos_jornales_activo boolean,
    mayores_costos_jornales_valor double precision,
    mayores_costos_materiales_activo boolean,
    mayores_costos_materiales_valor double precision,
    mayores_costos_otros_costos_activo boolean,
    mayores_costos_otros_costos_valor double precision,
    mayores_costos_profesionales_activo boolean,
    mayores_costos_profesionales_valor double precision,
    mayores_costos_valor_general double precision,
    numero_version integer,
    tiempo_estimado_terminacion integer,
    total_general double precision,
    total_honorarios_calculado numeric(15,2),
    total_materiales double precision,
    total_presupuesto numeric(15,2),
    total_presupuesto_con_honorarios numeric(15,2),
    total_profesionales double precision,
    vencimiento date,
    cliente_id bigint,
    empresa_id bigint NOT NULL,
    fecha_ultima_modificacion_estado timestamp(6) without time zone,
    id bigint NOT NULL,
    numero_presupuesto bigint,
    obra_id bigint,
    honorarios_configuracion_presupuesto_tipo character varying(20),
    honorarios_jornales_tipo character varying(20),
    honorarios_materiales_tipo character varying(20),
    honorarios_otros_costos_tipo character varying(20),
    honorarios_profesionales_tipo character varying(20),
    honorarios_tipo_general character varying(20),
    mayores_costos_configuracion_presupuesto_tipo character varying(20),
    mayores_costos_honorarios_tipo character varying(20),
    mayores_costos_jornales_tipo character varying(20),
    mayores_costos_materiales_tipo character varying(20),
    mayores_costos_otros_costos_tipo character varying(20),
    mayores_costos_profesionales_tipo character varying(20),
    mayores_costos_tipo_general character varying(20),
    modo_presupuesto character varying(50) NOT NULL,
    comentarios_cliente text,
    descripcion character varying(255),
    descripcion_detallada text,
    direccion_obra character varying(255),
    direccion_obra_altura character varying(255) NOT NULL,
    direccion_obra_barrio character varying(255),
    direccion_obra_calle character varying(255) NOT NULL,
    direccion_obra_departamento character varying(255),
    direccion_obra_piso character varying(255),
    direccion_obra_torre character varying(255),
    direccion_particular character varying(255),
    especificaciones_tecnicas text,
    estado character varying(255),
    mail character varying(255),
    mayores_costos_explicacion text,
    mayores_costos_nombre_rubro_importado character varying(255),
    mayores_costos_rubro_importado character varying(255),
    nombre_obra character varying(255),
    nombre_solicitante character varying(255),
    notas_adicionales text,
    observaciones character varying(255),
    observaciones_internas text,
    profesionales_necesarios character varying(255),
    requisitos_especiales text,
    telefono character varying(255),
    CONSTRAINT presupuesto_no_cliente_estado_check CHECK (((estado)::text = ANY ((ARRAY['A_ENVIAR'::character varying, 'BORRADOR'::character varying, 'MODIFICADO'::character varying, 'ENVIADO'::character varying, 'APROBADO'::character varying, 'OBRA_A_CONFIRMAR'::character varying, 'EN_EJECUCION'::character varying, 'TERMINADO'::character varying])::text[]))),
    CONSTRAINT presupuesto_no_cliente_modo_presupuesto_check CHECK (((modo_presupuesto)::text = ANY ((ARRAY['TRADICIONAL'::character varying, 'TRABAJOS_SEMANALES'::character varying])::text[])))
);


