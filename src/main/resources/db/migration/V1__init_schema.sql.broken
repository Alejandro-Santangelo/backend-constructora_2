CREATE TABLE public.pagos_material_obra (
    cantidad numeric(15,2),
    fecha_pago date NOT NULL,
    monto numeric(15,2) NOT NULL,
    precio_unitario numeric(15,2),
    empresa_id bigint NOT NULL,
    etapa_diaria_id bigint,
    fecha_actualizacion timestamp(6) without time zone,
    fecha_registro timestamp(6) without time zone NOT NULL,
    gasto_general_id bigint,
    id bigint NOT NULL,
    item_calculadora_id bigint,
    jornal_calculadora_id bigint,
    material_calculadora_id bigint,
    presupuesto_no_cliente_id bigint,
    profesional_calculadora_id bigint,
    estado character varying(50) NOT NULL,
    metodo_pago character varying(50),
    tipo_pago character varying(50) NOT NULL,
    numero_comprobante character varying(100),
    usuario_registro character varying(100),
    comprobante_url character varying(500),
    concepto character varying(500) NOT NULL,
    motivo_anulacion text,
    observaciones text,
    CONSTRAINT pagos_material_obra_estado_check CHECK (((estado)::text = ANY ((ARRAY['PAGADO'::character varying, 'PENDIENTE'::character varying, 'ANULADO'::character varying])::text[]))),
    CONSTRAINT pagos_material_obra_metodo_pago_check CHECK (((metodo_pago)::text = ANY ((ARRAY['EFECTIVO'::character varying, 'TRANSFERENCIA'::character varying, 'CHEQUE'::character varying, 'DEBITO'::character varying, 'CREDITO'::character varying])::text[]))),
    CONSTRAINT pagos_material_obra_tipo_pago_check CHECK (((tipo_pago)::text = ANY ((ARRAY['MATERIALES'::character varying, 'GASTOS_GENERALES'::character varying, 'OTROS_COSTOS'::character varying, 'OTROS'::character varying])::text[])))
);


